{
  "name": "board-games-online",
  "version": "1.0.0",
  "description": "Monorepo for the board-games-online platform",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @bgo/web dev",
    "dev:server": "pnpm --filter @bgo/server start:dev",
    "dev": "concurrently -n server,web -c blue,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
