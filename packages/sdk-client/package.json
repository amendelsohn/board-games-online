{
  "name": "@bgo/sdk-client",
  "version": "0.1.0",
  "description": "Board-games-online client SDK (React component interfaces for game modules)",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "dependencies": {
    "@bgo/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
